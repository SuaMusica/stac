{
    "type": "scaffold",
    "body": {
        "type": "customScrollView",
        "slivers": [
            {
                "type": "sliverSafeArea",
                "top": true,
                "bottom": true,
                "sliver": {
                    "type": "sliverToBoxAdapter",
                    "child": {
                        "type": "container",
