{
    "type": "scaffold",
    "body": {
        "type": "customScrollView",
        "slivers": [
            {
                "type": "sliverPadding",
                "padding": 16.0,
                "sliver": {
                    "type": "sliverToBoxAdapter",
                    "child": {
                        "type": "container",
                        "height": 150,
                        "color": "#4CAF50",
                        "child": {
                            "type": "center",
                            "child": {
                                "type": "text",
                                "data": "I am a Box inside a SliverPadding!",
                                "style": {
                                    "color": "#FFFFFF",
                                    "fontWeight": "bold"
                                }
                            }
                        }
                    }
                }
            }
        ]
    }
}